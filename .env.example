# --- AI analyst (/api/ask) ---
# Anthropic API key. Server-side only — never ship to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# --- Live data backend (Neon Postgres) ---
# Neon connection string (use the pooled connection string from the Neon console).
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Shared secret that gates /api/refresh. Vercel Cron sends it as "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=change-me

# Optional: the EEA CO₂ monitoring CSV URL for the full EU load (npm run ingest:eu).
# Leave unset to seed from the bundled official extract.
# EEA_EU_URL=https://.../eea-co2-cars-2025.csv
# EEA_EU_DELIMITER=,
